# Copy to .env on unRAID only — never commit real tokens.

# --- Schedule ---
# Hours between update cycles (1–6 recommended). Default 1 for near-live.
UPDATE_HOURS=1
# Run once immediately on container start (1) or wait a full interval (0)
RUN_ON_START=1
TZ=America/Chicago

# --- Repo mode ---
# clone  = git clone/pull inside container (default, best for headless Unraid)
# mount  = use a host-mounted checkout at REPO_DIR
MOUNT_MODE=clone
REPO_DIR=/workspace/sunrise
REPO_URL=https://github.com/brivera2005/thesunriseparty.git
REPO_BRANCH=master
# When MOUNT_MODE=mount, set host path in docker-compose volume and optionally:
# SKIP_GIT_PULL=0

# --- Cloudflare Pages (required to publish) ---
# Create token: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Account.Cloudflare Pages — Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
PAGES_PROJECT=thesunriseparty
PAGES_BRANCH=main

# --- Optional data sources ---
# Free key: https://api.congress.gov/sign-up
# Optional: improves bill-action roll discovery + distracted Congress stubs.
# Member Yea/Nay still refresh from GovTrack (House) + Senate LIS without a key.
CONGRESS_API_KEY=

# --- Optional GitHub push of auto-ingested data ---
# fine-grained or classic PAT with contents:write on brivera2005/thesunriseparty
GITHUB_TOKEN=
PUSH_DATA_UPDATES=0
GIT_AUTHOR_NAME=Project Sunrise Updater
GIT_AUTHOR_EMAIL=sunrise-updater@users.noreply.github.com

# --- Tracker ingest knobs ---
# TRACKER_FR_AUTO defaults OFF — curated tracker only. Set =1 to opt in to
# high-signal short-title FR EOs (never ceremonial / Section 301 dumps).
# TRACKER_FR_AUTO=0
TRACKER_LOOKBACK_DAYS=45
TRACKER_MAX_NEW=15
TRACKER_MAX_TITLE_CHARS=120
FR_PRESIDENT=donald-trump

# --- Distracted Watch ingest knobs ---
# ALL Distracted auto sources default OFF. Live Distracted = curated only.
# Never set DISTRACTED_FR_AUTO=1 unless you accept hard-signal FR flashbangs.
# DISTRACTED_FR_AUTO=0
# DISTRACTED_RSS_AUTO=0
# DISTRACTED_CONGRESS_AUTO=0
DISTRACTED_LOOKBACK_DAYS=21
DISTRACTED_MAX_NEW=8
# Optional RSS override (default NPR Politics)
# DISTRACTED_RSS_URL=https://feeds.npr.org/1014/rss.xml

# --- Debug ---
# SKIP_BUILD=1
# SKIP_DEPLOY=1
